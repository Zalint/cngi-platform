# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cngi_db
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=votre_secret_jwt_aleatoire_securise_changez_moi
JWT_EXPIRES_IN=24h

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# OpenAI (génération de rapports)
OPENAI_API_KEY=votre_cle_openai
OPENAI_MODEL=gpt-4.1-mini

# Resend (emails transactionnels : bienvenue, assignation de mesure, changement de statut)
# Si RESEND_API_KEY est vide, aucun email n'est envoyé (no-op silencieux).
#
# Pour utiliser le domaine cngiri.com comme expéditeur :
#   1. Ajouter le domaine sur https://resend.com/domains
#   2. Configurer les DNS (MX + 2 TXT pour SPF/DKIM) chez le registrar
#   3. Une fois vérifié, mettre RESEND_FROM=CNGIRI <noreply@cngiri.com>
#
# Tant que le domaine n'est pas vérifié, garder onboarding@resend.dev (sandbox Resend
# qui n'envoie qu'à l'adresse de l'owner du compte Resend).
RESEND_API_KEY=
RESEND_FROM=CNGIRI <noreply@cngiri.com>
APP_URL=https://www.cngiri.com
