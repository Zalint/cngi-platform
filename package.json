{
  "name": "cngi-platform",
  "version": "1.0.0",
  "description": "Plateforme de suivi des actions CNGI - Comité National de Gestion des Inondations",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:schema": "psql -U postgres -d cngi_db -f db/schema.sql",
    "db:seed": "node db/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/app.js",
      "!src/config/**",
      "!src/routes/**"
    ],
    "setupFiles": ["<rootDir>/tests/setup.js"]
  },
  "keywords": [
    "cngi",
    "gestion",
    "inondations",
    "projets"
  ],
  "author": "CNGI Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "marked": "^18.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.1"
  }
}
